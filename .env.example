# Glimmer deployment configuration
# Copy this file to .env and fill in your values

# GitHub OAuth (create an app at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Master key for JWT signing + credential encryption (generate: openssl rand -hex 32)
GLIMMER_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# PostgreSQL password
DB_PASSWORD=change-me-to-a-secure-password

# OAuth redirect URI (set to your actual domain in production)
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback
